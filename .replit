modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
EXT_DB_HOST = "114.132.84.75"
EXT_DB_PORT = "5432"
EXT_DB_NAME = "sciblock_v2"
EXT_DB_USER = "postgres"
EXT_DATABASE_URL = "postgresql://postgres:081e547e37a0f121dbed1c930171365d@114.132.84.75:5432/sciblock_v2"

[nix]
channel = "stable-25_05"
